generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Passage {
  id            Int            @id @default(autoincrement())
  imageUrl      String? // legacy: 단일 이미지 URL. 새 코드는 images 사용
  ocrText       String?
  year          Int?
  month         Int?
  grade         Int?
  source        String?
  office        String? // legacy
  area          String? // 문학 / 독서 / 화작 / 언매
  startNo       Int?
  endNo         Int?
  questionRange String?
  pdfDocumentId Int?
  pdfDocument   PdfDocument?   @relation(fields: [pdfDocumentId], references: [id], onDelete: SetNull)
  questions     Question[]
  images        PassageImage[]
  tags          PassageTag[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([pdfDocumentId])
}

model PassageImage {
  id        Int      @id @default(autoincrement())
  passageId Int
  passage   Passage  @relation(fields: [passageId], references: [id], onDelete: Cascade)
  imageUrl  String
  ocrText   String?
  order     Int      @default(0) // 단별 순서
  pageNum   Int? // 원본 PDF 페이지
  boxX      Float? // 원본 픽셀 좌표 (scale 2.0 기준)
  boxY      Float?
  boxW      Float?
  boxH      Float?
  createdAt DateTime @default(now())

  @@index([passageId])
}

model PdfDocument {
  id           Int        @id @default(autoincrement())
  name         String
  blobUrl      String // Vercel Blob URL
  fileHash     String     @unique // SHA-256 (중복 PDF 감지)
  pageCount    Int?
  uploadedById Int?
  createdAt    DateTime   @default(now())
  passages     Passage[]
  questions    Question[]

  @@index([createdAt])
}

model Question {
  id                Int                       @id @default(autoincrement())
  passageId         Int?
  passage           Passage?                  @relation(fields: [passageId], references: [id])
  imageUrl          String
  ocrText           String?
  keywords          String? // legacy
  answer            String?
  difficulty        String?
  questionNo        Int?
  // 모고입력키워드 — 예: m01231117 (m + 고1(01) + 23년 + 11월 + 17번). 검색·정렬용.
  sourceKey         String?
  // 사용자가 이미지에 적힌 문제번호를 그대로 입력 (1~999). 본인 교재에서의 번호.
  imageNo           Int?
  // 단독 문제(passage 없음)일 때 직접 보유할 수 있는 메타. passage 있으면 그쪽 우선.
  year              Int?
  month             Int?
  grade             Int?
  area              String?
  pdfDocumentId     Int?
  pdfDocument       PdfDocument?              @relation(fields: [pdfDocumentId], references: [id], onDelete: SetNull)
  pageNum           Int?
  boxX              Float?
  boxY              Float?
  boxW              Float?
  boxH              Float?
  tags              QuestionTag[]
  grammarCategories QuestionGrammarCategory[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([pdfDocumentId])
  @@index([sourceKey])
  @@index([imageNo])
}

model Tag {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  questions QuestionTag[]
  passages  PassageTag[]
  createdAt DateTime      @default(now())
}

model PassageTag {
  passageId Int
  tagId     Int
  passage   Passage  @relation(fields: [passageId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([passageId, tagId])
  @@index([tagId])
}

model QuestionTag {
  questionId Int
  tagId      Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([questionId, tagId])
  @@index([tagId])
}

model GrammarCategory {
  id        Int                       @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    GrammarCategory?          @relation("GrammarHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  GrammarCategory[]         @relation("GrammarHierarchy")
  order     Int                       @default(0)
  questions QuestionGrammarCategory[]
  createdAt DateTime                  @default(now())

  @@index([parentId])
}

model QuestionGrammarCategory {
  questionId Int
  categoryId Int
  question   Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  category   GrammarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@id([questionId, categoryId])
  @@index([categoryId])
}

// 시험지 (Exam Paper) — admin이 만드는 출제 단위
// status: "draft" = 현재 작업중 (사용자당 1개만), "saved" = 출제 완료/저장됨
model ExamSet {
  id                   Int                   @id @default(autoincrement())
  ownerId              Int // 소유자 (User.id). draft는 사용자당 1개.
  status               String                @default("draft") // draft | saved
  title                String? // 시험지 제목
  subTitle             String? // 소제목 (예: "고1 2025년 3월 - 교육청 모의평가")
  academyName          String? // 학원명
  grade                Int? // 학년
  durationMin          Int? // 시험 시간(분)
  totalScore           Int? // 총점
  pdfUrl               String? // 출제 후 저장된 PDF URL (선택)
  // 학생 오답노트 공개 설정
  isStudentPublic      Boolean               @default(false)
  studentAccessSlug    String?               @unique // /student/exam/[slug] 로 접근
  wrongNoteDesign      String                @default("oreum") // "mexx" | "oreum"
  items                ExamItem[]
  wrongNoteSubmissions WrongNoteSubmission[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([ownerId, status])
  @@index([isStudentPublic])
}

// 시험지 안에 담긴 항목(지문 세트 또는 단독 문제)
// kind="passage" → passageId 있음 (지문 + 그 지문의 문제들 통째)
// kind="question" → questionId 있음 (단독 문제 또는 "문제만 담기" 선택한 경우)
model ExamItem {
  id               Int                   @id @default(autoincrement())
  examSetId        Int
  examSet          ExamSet               @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  kind             String // "passage" | "question"
  passageId        Int?
  questionId       Int?
  sectionLabel     String? // 보라색 태그용 (예: "기출 문제", "변형 문제 1")
  order            Int                   @default(0)
  // 이미지 표시 옵션 (출제 시점에 사용자가 조정)
  imageScale       Float                 @default(1.0) // 단 폭 대비 가로 비율 (0.3 ~ 2.0)
  imageAlign       String                @default("center") // left | center | right
  cropTop          Float                 @default(0) // legacy CSS crop (자르기 데이터. 새 croppedImageUrl 있으면 무시됨)
  cropBottom       Float                 @default(0)
  cropLeft         Float                 @default(0)
  cropRight        Float                 @default(0)
  // 사용자가 자르기 사각형을 확정하면 canvas로 크롭한 실제 이미지 파일이 Vercel Blob에 저장되고
  // 그 URL이 여기 들어감. 우선 사용. null이면 원본 사용.
  croppedImageUrl  String?
  wrongNoteAnswers WrongNoteAnswerItem[]
  createdAt        DateTime              @default(now())

  @@unique([examSetId, kind, passageId, questionId])
  @@index([examSetId])
}

// === 오답노트 (재설계) ===
// 학생이 시험지 링크(/student/exam/[slug])로 접속 → 이름/전화/학원(반) 입력 →
// 틀린 문제 체크 → 제출. Admin이 /admin/wrong-notes 에서 확인 후 PDF 다운로드.

// 학생 제출 1건
model WrongNoteSubmission {
  id             Int                   @id @default(autoincrement())
  examSetId      Int
  examSet        ExamSet               @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  studentName    String // 학생 이름
  studentPhone   String? // 전화번호
  studentAcademy String? // 학원(반) — 자유 텍스트
  status         String                @default("pending") // pending | processed
  createdAt      DateTime              @default(now())
  processedAt    DateTime?
  answers        WrongNoteAnswerItem[]

  @@index([status, createdAt])
  @@index([examSetId])
}

// 학생이 틀렸다고 체크한 ExamItem 참조
model WrongNoteAnswerItem {
  id           Int                 @id @default(autoincrement())
  submissionId Int
  submission   WrongNoteSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examItemId   Int
  examItem     ExamItem            @relation(fields: [examItemId], references: [id], onDelete: Cascade)
  createdAt    DateTime            @default(now())

  @@unique([submissionId, examItemId])
  @@index([submissionId])
}
