generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Passage {
  id            Int            @id @default(autoincrement())
  imageUrl      String? // legacy: 단일 이미지 URL. 새 코드는 images 사용
  ocrText       String?
  year          Int?
  month         Int?
  grade         Int?
  source        String?
  office        String? // legacy
  area          String? // 문학 / 독서 / 화작 / 언매
  startNo       Int?
  endNo         Int?
  questionRange String?
  pdfDocumentId Int?
  pdfDocument   PdfDocument?   @relation(fields: [pdfDocumentId], references: [id], onDelete: SetNull)
  questions     Question[]
  images        PassageImage[]
  tags          PassageTag[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([pdfDocumentId])
}

model PassageImage {
  id        Int      @id @default(autoincrement())
  passageId Int
  passage   Passage  @relation(fields: [passageId], references: [id], onDelete: Cascade)
  imageUrl  String
  ocrText   String?
  order     Int      @default(0) // 단별 순서
  pageNum   Int? // 원본 PDF 페이지
  boxX      Float? // 원본 픽셀 좌표 (scale 2.0 기준)
  boxY      Float?
  boxW      Float?
  boxH      Float?
  createdAt DateTime @default(now())

  @@index([passageId])
}

model PdfDocument {
  id           Int        @id @default(autoincrement())
  name         String
  blobUrl      String // Vercel Blob URL
  fileHash     String     @unique // SHA-256 (중복 PDF 감지)
  pageCount    Int?
  uploadedById Int?
  createdAt    DateTime   @default(now())
  passages     Passage[]
  questions    Question[]

  @@index([createdAt])
}

model Question {
  id                Int                       @id @default(autoincrement())
  passageId         Int?
  passage           Passage?                  @relation(fields: [passageId], references: [id])
  imageUrl          String
  ocrText           String?
  keywords          String? // legacy
  answer            String?
  difficulty        String?
  questionNo        Int?
  // 단독 문제(passage 없음)일 때 직접 보유할 수 있는 메타. passage 있으면 그쪽 우선.
  year              Int?
  month             Int?
  grade             Int?
  area              String?
  pdfDocumentId     Int?
  pdfDocument       PdfDocument?              @relation(fields: [pdfDocumentId], references: [id], onDelete: SetNull)
  pageNum           Int?
  boxX              Float?
  boxY              Float?
  boxW              Float?
  boxH              Float?
  tags              QuestionTag[]
  grammarCategories QuestionGrammarCategory[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([pdfDocumentId])
}

model Tag {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  questions QuestionTag[]
  passages  PassageTag[]
  createdAt DateTime      @default(now())
}

model PassageTag {
  passageId Int
  tagId     Int
  passage   Passage  @relation(fields: [passageId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([passageId, tagId])
  @@index([tagId])
}

model QuestionTag {
  questionId Int
  tagId      Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([questionId, tagId])
  @@index([tagId])
}

model GrammarCategory {
  id        Int                       @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    GrammarCategory?          @relation("GrammarHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  GrammarCategory[]         @relation("GrammarHierarchy")
  order     Int                       @default(0)
  questions QuestionGrammarCategory[]
  createdAt DateTime                  @default(now())

  @@index([parentId])
}

model QuestionGrammarCategory {
  questionId Int
  categoryId Int
  question   Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  category   GrammarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@id([questionId, categoryId])
  @@index([categoryId])
}

// 시험지 (Exam Paper) — admin이 만드는 출제 단위
// status: "draft" = 현재 작업중 (사용자당 1개만), "saved" = 출제 완료/저장됨
model ExamSet {
  id          Int        @id @default(autoincrement())
  ownerId     Int // 소유자 (User.id). draft는 사용자당 1개.
  status      String     @default("draft") // draft | saved
  title       String? // 시험지 제목
  subTitle    String? // 소제목 (예: "고1 2025년 3월 - 교육청 모의평가")
  academyName String? // 학원명
  grade       Int? // 학년
  durationMin Int? // 시험 시간(분)
  totalScore  Int? // 총점
  pdfUrl      String? // 출제 후 저장된 PDF URL (선택)
  items       ExamItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([ownerId, status])
}

// 시험지 안에 담긴 항목(지문 세트 또는 단독 문제)
// kind="passage" → passageId 있음 (지문 + 그 지문의 문제들 통째)
// kind="question" → questionId 있음 (단독 문제 또는 "문제만 담기" 선택한 경우)
model ExamItem {
  id           Int      @id @default(autoincrement())
  examSetId    Int
  examSet      ExamSet  @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  kind         String // "passage" | "question"
  passageId    Int?
  questionId   Int?
  sectionLabel String? // 보라색 태그용 (예: "기출 문제", "변형 문제 1")
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([examSetId, kind, passageId, questionId])
  @@index([examSetId])
}

// === 오답워크북 ===

// 학원 마스터 — 학원 별 코드 + 기본 디자인 매핑
model Academy {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  code              String             @unique // 학생이 입력할 코드 (예: OREUM-2026)
  defaultDesign     String             @default("oreum") // "mexx" | "oreum"
  logoUrl           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  wrongNoteRequests WrongNoteRequest[]
}

// 회차(시험지 풀) — 학생이 풀 수 있는 100~200문제 모음
// 시험지 제작용 ExamSet과는 별개 모델 (학생용 풀)
model ExamRound {
  id                 Int                @id @default(autoincrement())
  title              String // 회차 이름 (예: "2026 6월 모의평가 1회")
  subTitle           String? // 서브 (예: "독서·문학 영역")
  grade              Int? // 대상 학년
  isPublic           Boolean            @default(false) // 학생에게 보이는지
  requireAcademyCode Boolean            @default(true) // 학원 코드 필요 여부
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  items              RoundItem[]
  wrongNoteRequests  WrongNoteRequest[]

  @@index([isPublic])
}

// 회차에 담긴 항목 (지문 세트 또는 단독 문제) — ExamItem과 같은 구조
model RoundItem {
  id           Int               @id @default(autoincrement())
  roundId      Int
  round        ExamRound         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  kind         String // "passage" | "question"
  passageId    Int?
  questionId   Int?
  order        Int               @default(0)
  createdAt    DateTime          @default(now())
  wrongAnswers WrongNoteAnswer[]

  @@unique([roundId, kind, passageId, questionId])
  @@index([roundId])
}

// 학생 오답노트 요청 — 학생 외부 페이지에서 제출됨
model WrongNoteRequest {
  id          Int               @id @default(autoincrement())
  academyId   Int?
  academy     Academy?          @relation(fields: [academyId], references: [id], onDelete: SetNull)
  roundId     Int
  round       ExamRound         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  studentName String
  school      String?
  grade       Int?
  design      String            @default("oreum") // 출력 디자인 (학원의 default 따라감)
  status      String            @default("pending") // pending | processed
  pdfUrl      String?
  createdAt   DateTime          @default(now())
  processedAt DateTime?
  answers     WrongNoteAnswer[]

  @@index([status, createdAt])
  @@index([academyId])
  @@index([roundId])
}

// 학생이 틀렸다고 체크한 항목 (RoundItem 참조)
model WrongNoteAnswer {
  id          Int              @id @default(autoincrement())
  requestId   Int
  request     WrongNoteRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  roundItemId Int
  roundItem   RoundItem        @relation(fields: [roundItemId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@unique([requestId, roundItemId])
  @@index([requestId])
}
